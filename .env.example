# ==================================================
#         Proxy EasyProxy Configuration
# ==================================================
#
# Rename this file to ".env" and uncomment the variables you want to use.
# You can specify multiple proxies for a variable by separating them with a comma.
# The system will randomly select a proxy from the list for each request.
#
# Supported formats: http, https, socks5, socks5h, socks4, socks4a
# Example with authentication: http://user:password@host:port
#

# --- Global Proxy ---
# Used for all requests that don't have a specific rule in TRANSPORT_ROUTES.
# Example: GLOBAL_PROXY=http://myproxy.com:8080,socks5://user:pass@anotherproxy.com:1080
#GLOBAL_PROXY=

# --- Transport Rules (TRANSPORT_ROUTES) ---
# Advanced system for routing proxy based on URL patterns.
# Format: {URL=pattern, PROXY=proxy_url, DISABLE_SSL=true}, {URL=pattern2, PROXY=proxy_url2, DISABLE_SSL=true}
# - URL: pattern to search in the URL (e.g. vavoo.to, giokko.ru)
# - PROXY: proxy to use (leave empty for direct connection)
# - DISABLE_SSL: to disable SSL verification
# Examples:
# TRANSPORT_ROUTES={URL=vavoo.to, PROXY=socks5://proxy1:1080, DISABLE_SSL=true}
#TRANSPORT_ROUTES=

# --- Specific Note for MaxStream / Uprot ---
# Providers like MaxStream and Uprot.net aggressively block Datacenter IPs (AWS, Oracle, etc.).
# To make them work on a cloud server, use a residential proxy ONLY for these domains:
# TRANSPORT_ROUTES={URL=uprot.net, PROXY=http://user:pass@res-proxy:port},{URL=maxstream.video, PROXY=http://user:pass@res-proxy:port}
#
# NOTE: This step is NOT necessary if you are using the "Full" version (Dockerfile.full) 
# with Cloudflare WARP enabled (ENABLE_WARP=true), as WARP provides a suitable exit IP.

# --- Password API ---
# Protects access to the proxy API. If set, it must be passed
# as a query parameter (?api_password=...) or header (x-api-password).
#API_PASSWORD=ep

# --- Server Port ---
# Specifies the port on which the server should listen (default: 7860)
#PORT=7860

# --- Log Level ---
# Controls the verbosity of the logs.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: WARNING)
#LOG_LEVEL=INFO
 
# --- Worker Processes ---
# Number of Gunicorn worker processes.
# If not set, it will automatically use the number of CPU cores (nproc).
#WORKERS=2

# --- MPD Processing Mode & Remuxing ---
# MPD_MODE: Choose how to handle MPD/DASH streams:
# - legacy: Uses mpd_converter + drm_decrypter (lightweight, default if set)
# - ffmpeg: Full transcoding via FFmpeg (1080p High Quality, best stability, high CPU)
# - none: Disables both DASH conversion and fMP4 remuxing (direct raw streams)
# If NOT SET, it defaults to 'legacy'.
#MPD_MODE=


# --- WARP Configuration ---
# Enable integrated Cloudflare WARP (Full version only).
# Routes the whole container through the WARP tunnel, with optional excluded hosts.
# NOTE: Requires --cap-add=NET_ADMIN and --device /dev/net/tun in Docker.
#ENABLE_WARP=false
# Use wireproxy when the host cannot expose /dev/net/tun.
#WARP_MODE=warp-cli
#WARP_MODE=wireproxy
# If a provider has problems behind WARP, add its host here instead of using URL query params.
# Use `example.com` for the root domain only. Use `*.example.com` for subdomains.
# If you need both, include both entries.
# Example:
#WARP_EXCLUDED_HOSTS=example.com,*.example.com
# Multi-domain example:
#WARP_LICENSE_KEY=

# --- DVR/Recording Settings ---
# Enable DVR/recording functionality (default: false)
#DVR_ENABLED=false

# Directory where recordings will be saved (default: recordings)
#RECORDINGS_DIR=recordings

# Maximum recording duration in seconds (default: 28800 = 8 hours)
#MAX_RECORDING_DURATION=28800

# Auto-delete recordings older than X days (default: 7)
#RECORDINGS_RETENTION_DAYS=7

# === FlareSolverr / Byparr Configuration ===
# NOTE: If you are using the "Full" version (Docker/Monolith), these services are 
# managed internally and you don't need to specify these URLs.
# (IT: Se si usa la versione FULL, i servizi sono gestiti internamente e non servono)

# FlareSolverr: Used to bypass Cloudflare on Mixdrop, Deltabit, safego.cc, etc.
# FLARESOLVERR_URL=http://flaresolverr:8191
# FLARESOLVERR_TIMEOUT=60
