# ==================================================
#         EasyProxy Configuration
# ==================================================
#
# Rename this file to ".env" and edit as needed.
# Most settings are now managed via the Admin Panel (live, no restart).
# Only essential env vars remain here.

# --- Required ---
# Password to protect the proxy API and admin panel
#API_PASSWORD=your_password_here

# --- Optional ---
# Server port (default: 7860)
#PORT=7860

# Number of Gunicorn worker processes (default: auto based on CPU cores)
#WORKERS=2